# Keep actual credentials only in .env.local (which is ignored by Git).
NASA_API_KEY=your_nasa_api_key
NASA_APOD_URL=https://api.nasa.gov/planetary/apod
NASA_MARS_URL=https://api.nasa.gov/mars-photos/api/v1
NASA_NEO_URL=https://api.nasa.gov/neo/rest/v1
NASA_DONKI_URL=https://api.nasa.gov/DONKI
ISS_POSITION_URL=http://api.open-notify.org/iss-now.json
PEOPLE_IN_SPACE_URL=http://api.open-notify.org/astros.json
USGS_BASE_URL=https://earthquake.usgs.gov/fdsnws/event/1/query
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
LAUNCH_LIBRARY_URL=https://ll.thespacedevs.com/2.2.0
NVIDIA_API_KEY=your_nvidia_api_key
# Optional second key used as a briefing fallback.
NVIDIA_ALT_API_KEY=your_alt_nvidia_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# Briefing LLM. A fast instruction model is required — reasoning models (e.g.
# nemotron-3-ultra-550b) stream their chain-of-thought and time out in serverless.
NVIDIA_LLM_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_VISION_API_KEY=your_vision_api_key
NVIDIA_VISION_MODEL=moonshotai/kimi-k2.6
NEXT_PUBLIC_APP_NAME=ORBITER
# ISS/globe poll interval (ms).
NEXT_PUBLIC_REFRESH_INTERVAL=5000
NEXT_PUBLIC_AI_BRIEFING_INTERVAL=3600
# Set to "false" to stop the globe auto-rotating.
NEXT_PUBLIC_GLOBE_AUTO_ROTATE=true
